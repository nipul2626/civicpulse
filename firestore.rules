rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function isCoordinator() {
      return isSignedIn() &&
             getUserData() != null &&
             getUserData().role == 'coordinator';
    }

    function isVolunteer() {
      return isSignedIn() &&
             getUserData() != null &&
             getUserData().role == 'volunteer';
    }

    function isSameOrg(orgId) {
      return getUserData() != null &&
             getUserData().orgId == orgId;
    }

    // ── Needs ─────────────────────────────────────────
    match /needs/{needId} {
      allow create: if true;
      allow read: if isSignedIn();
      allow update: if isSignedIn() &&
                    isCoordinator() &&
                    isSameOrg(resource.data.orgId);
      allow delete: if false;
    }

    // ── Tasks ─────────────────────────────────────────
    match /tasks/{taskId} {
      allow read: if isSignedIn() &&
        (
          (isCoordinator() && isSameOrg(resource.data.orgId)) ||
          resource.data.assignedVolunteer == request.auth.uid
        );

      allow create: if isSignedIn() &&
                    isCoordinator() &&
                    isSameOrg(request.resource.data.orgId);

      allow update: if isSignedIn() &&
        (
          (isCoordinator() && isSameOrg(resource.data.orgId)) ||
          resource.data.assignedVolunteer == request.auth.uid
        );

      allow delete: if false;
    }

    // ── Volunteers ─────────────────────────────────────
    match /volunteers/{volunteerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
        (isOwner(volunteerId) || isCoordinator());
    }

    // ── Users ──────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn() &&
        (isOwner(userId) || isCoordinator());

      allow create: if request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // ── Organizations ──────────────────────────────────
    match /organizations/{orgId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
                    isCoordinator() &&
                    isSameOrg(orgId);
    }

    // ── Resources ──────────────────────────────────────
    match /resources/{resourceId} {
      allow read, write: if isSignedIn() && isCoordinator();
    }

    // ── AI Queue ───────────────────────────────────────
    match /aiQueue/{jobId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── Handoff Requests ───────────────────────────────
    match /handoffRequests/{requestId} {
      allow read, write: if isSignedIn() && isCoordinator();
    }
  }
}