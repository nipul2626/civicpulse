rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isCoordinator() {
      return getUserData().role == 'coordinator';
    }

    function isVolunteer() {
      return getUserData().role == 'volunteer';
    }

    function isSameOrg(orgId) {
      return getUserData().orgId == orgId;
    }

    // ── Needs: public create, auth read, coordinator update ───────────────────
    match /needs/{needId} {
      allow create: if true;
      allow read:   if isSignedIn();
      allow update: if isSignedIn() && isCoordinator();
      allow delete: if false;
    }

    // ── Tasks: coordinator create, volunteer can update own ───────────────────
    match /tasks/{taskId} {
      allow read:   if isSignedIn() &&
                      (isCoordinator() ||
                       resource.data.assignedVolunteer == request.auth.uid);
      allow create: if isSignedIn() && isCoordinator();
      allow update: if isSignedIn() &&
                      (isCoordinator() ||
                       resource.data.assignedVolunteer == request.auth.uid);
      allow delete: if false;
    }

    // ── Volunteers: auth read, own or coordinator write ───────────────────────
    match /volunteers/{volunteerId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() &&
                     (isOwner(resource.data.userId) || isCoordinator());
    }

    // ── Users: read own or coordinator, create self, update self ─────────────
    match /users/{userId} {
      allow read:   if isSignedIn() && (isOwner(userId) || isCoordinator());
      allow create: if request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // ── Organizations: auth read, same-org coordinator write ─────────────────
    match /organizations/{orgId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && isCoordinator() && isSameOrg(orgId);
    }

    // ── Resources: coordinator only ───────────────────────────────────────────
    match /resources/{resourceId} {
      allow read:  if isSignedIn() && isCoordinator();
      allow write: if isSignedIn() && isCoordinator();
    }

    // ── AI Queue: read only for auth users, no client writes ─────────────────
    match /aiQueue/{jobId} {
      allow read:  if isSignedIn();
      allow write: if false;
    }

    // ── Handoff requests: coordinator only ────────────────────────────────────
    match /handoffRequests/{requestId} {
      allow read:  if isSignedIn() && isCoordinator();
      allow write: if isSignedIn() && isCoordinator();
    }
  }
}